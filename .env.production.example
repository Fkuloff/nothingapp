# Production Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=messenger
POSTGRES_PASSWORD=change-this-to-secure-password
POSTGRES_DB=messenger

# ============================================
# JWT Configuration
# ============================================
# IMPORTANT: Must be at least 32 characters long
# Generate: openssl rand -base64 32
JWT_SECRET=change-this-to-your-super-secret-jwt-key-minimum-32-characters

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://your-domain.com,https://your-domain.com

# ============================================
# MinIO Configuration (S3-compatible storage)
# ============================================
# IMPORTANT: Change MINIO_ROOT_PASSWORD to a strong password
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-to-secure-password
MINIO_BUCKET_NAME=messenger-uploads
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_CONSOLE_URL=http://your-domain.com:9001

# ============================================
# S3 Storage Configuration
# ============================================
# For MinIO (default):
# ENDPOINT: Internal endpoint for backend (Docker network)
# PUBLIC_ENDPOINT: Public endpoint for presigned URLs (browser access)
STORAGE_S3_ENDPOINT=http://minio:9000
STORAGE_S3_PUBLIC_ENDPOINT=http://your-domain.com:9000
STORAGE_S3_BUCKET=messenger-uploads
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=minioadmin
STORAGE_S3_SECRET_KEY=change-this-to-secure-password
STORAGE_S3_USE_SSL=false
STORAGE_S3_PRESIGNED_EXPIRY=3600

# For AWS S3 (production):
# Leave STORAGE_S3_ENDPOINT empty to use AWS endpoints
# STORAGE_S3_ENDPOINT=
# STORAGE_S3_BUCKET=your-s3-bucket-name
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY=your-aws-access-key
# STORAGE_S3_SECRET_KEY=your-aws-secret-key
# STORAGE_S3_USE_SSL=true
# STORAGE_S3_PRESIGNED_EXPIRY=3600

# ============================================
# Server Configuration
# ============================================
# Port for frontend service (80 for HTTP, 443 for HTTPS with reverse proxy)
PORT=80

# ============================================
# Docker Registry Configuration
# ============================================
# For GitHub Container Registry (ghcr.io)
# Replace 'your-username' with your GitHub username or organization
REGISTRY=ghcr.io/your-username/messenger-
TAG=latest

# ============================================
# Optional: PgAdmin (only for development)
# ============================================
# Uncomment these if you want to run PgAdmin
# PGADMIN_EMAIL=admin@admin.com
# PGADMIN_PASSWORD=admin
# PGADMIN_PORT=5050