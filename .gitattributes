# Enforce LF line endings for source files regardless of operator OS.
# Without this, files checked out on Windows get CRLF (Git autocrlf=true default),
# and Linux-side tools — notably gofmt in the CI/Docker linter — reject them.
#
# `text eol=lf` means:
#   - on checkout: write LF
#   - on commit: normalize to LF
*.go        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.sh        text eol=lf
Dockerfile  text eol=lf
.env*       text eol=lf
.gitignore  text eol=lf

# Binary, no conversion
*.png       binary
*.jpg       binary
*.svg       text eol=lf
*.ico       binary
*.apk       binary
*.zip       binary
