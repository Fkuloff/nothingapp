# Database Configuration
DB_URL=postgres://postgres:postgres@localhost:5432/messenger?sslmode=disable

# Server Configuration
PORT=8080

# JWT Secret (минимум 32 символа, используйте криптографически стойкий секрет в production!)
# Сгенерировать: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-replace-this-in-production

# CORS Origins (через запятую)
# Примеры: localhost и 127.0.0.1 могут использоваться браузерами взаимозаменяемо
# Добавьте оба варианта для фронтенд-портов (Vite обычно использует 5173-5174)
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:5173

# Storage Configuration
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_LOCAL_URL=http://localhost:8080/uploads

# Optional: S3 Storage (когда STORAGE_TYPE=s3)
# STORAGE_S3_BUCKET=my-bucket
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_CLOUDFRONT=https://cdn.example.com

# Environment (development/production)
ENV=development

