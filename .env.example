# ===========================================
# Production Environment Variables
# Domain: nothingapp.ru
# ===========================================

# Database
POSTGRES_USER=messenger
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=messenger

# JWT Secret (minimum 32 characters, no weak patterns)
JWT_SECRET=your_very_secure_jwt_secret_at_least_32_chars

# CORS - allowed origins (comma-separated for multiple)
# For production with HTTPS:
ALLOWED_ORIGINS=https://nothingapp.ru,https://www.nothingapp.ru
# For the Android APK (Capacitor WebView with androidScheme=https), also include:
#   https://localhost
# e.g. ALLOWED_ORIGINS=https://nothingapp.ru,https://localhost

# Port to expose (default 80, not used when using nginx-proxy)
PORT=80

# ===========================================
# SSL/HTTPS Configuration (Certbot)
# ===========================================

# Email for Let's Encrypt certificate notifications (REQUIRED)
ACME_EMAIL=your@email.com

# ===========================================
# MinIO Configuration (S3-compatible object storage)
# ===========================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_secure_minio_password_here
MINIO_BUCKET_NAME=messenger-uploads
# These ports are not exposed in production (accessed via nginx-proxy)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_CONSOLE_URL=https://minio-console.nothingapp.ru

# ===========================================
# S3 Storage Configuration
# ===========================================
# STORAGE_S3_ENDPOINT: Internal endpoint for backend (Docker network)
# STORAGE_S3_PUBLIC_ENDPOINT: Public endpoint for presigned URLs (browser access)
STORAGE_S3_ENDPOINT=http://minio:9000
STORAGE_S3_PUBLIC_ENDPOINT=https://minio.nothingapp.ru
STORAGE_S3_BUCKET=messenger-uploads
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=minioadmin
STORAGE_S3_SECRET_KEY=your_secure_minio_password_here
STORAGE_S3_USE_SSL=false
STORAGE_S3_PRESIGNED_EXPIRY=3600  # 1 hour in seconds

# ===========================================
# Web Push Notifications (VAPID)
# ===========================================
# Generate keys: go run -mod=mod your_vapid_keygen.go
# or use webpush.GenerateVAPIDKeys() from github.com/SherClockHolmes/webpush-go
# If not set, push notifications are disabled (graceful degradation)
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:admin@yourdomain.com

# ===========================================
# In-app self-update — admin endpoints
# ===========================================
# Gates POST /api/admin/releases (release registration). Sent by clients
# as the X-Admin-Key header; compared with constant-time equality.
# Empty value disables admin endpoints entirely (503 instead of 401).
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=

# ===========================================
# FCM (Firebase Cloud Messaging) — Android push
# ===========================================
# Path inside the backend container to the Firebase service account JSON.
# In prod, the file is mounted from ./fcm-credentials.json on the host.
# Leave unset to disable FCM (graceful degradation).
FCM_CREDENTIALS_PATH=/app/fcm-credentials.json

# ===========================================
# Docker Registry (for CI/CD)
# ===========================================
# REGISTRY=ghcr.io/yourusername/messenger-
# TAG=latest
