# Копируйте этот файл в нужную конфигурацию

# Для локального backend (localhost:8080)
# Скопируйте в .env.development или используйте: npm run dev:local
VITE_API_BASE_URL=http://localhost:8080

# Для backend на 192.168.1.101:8080
# Скопируйте в .env.dev101 (уже создан) или используйте: npm run dev:101
# VITE_API_BASE_URL=http://192.168.1.101:8080

# Для backend на 192.168.1.100:8080
# Скопируйте в .env.dev100 (уже создан) или используйте: npm run dev:100
# VITE_API_BASE_URL=http://192.168.1.100:8080

# Для другого адреса
# VITE_API_BASE_URL=http://YOUR_IP:YOUR_PORT
